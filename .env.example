# Copy to .env and fill in your values

# Domain for Traefik
MC_DOMAIN=abacus-mc.yourdomain.com

# OpenClaw Gateway
OPENCLAW_GATEWAY_HOST=your-openclaw-host
OPENCLAW_GATEWAY_PORT=45397
OPENCLAW_GATEWAY_URL=ws://your-openclaw-host:45397
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here
OPENCLAW_CLIENT_ID=your_client_id

# Auth
AUTH_USER=admin
AUTH_PASS=your_secure_password

# AI Models
DEFAULT_MODEL=claude-3-opus
FALLBACK_MODEL=claude-3-sonnet

# Optional
LOG_LEVEL=info
