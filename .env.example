# =====================================================
# Autonomous AI Startup - Environment Configuration
# =====================================================

# Authentication
AUTH_USER=admin
AUTH_PASS=change-me-on-first-login
API_KEY=generate-a-random-api-key

# Database
DATABASE_PATH=.data/startup.db

# OpenClaw Gateway Integration
OPENCLAW_CONFIG_PATH=/path/to/.openclaw/openclaw.json
OPENCLAW_STATE_DIR=/path/to/.openclaw
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
OPENCLAW_MEMORY_DIR=/home/user/clawd-agents

# AI Model Configuration
DEFAULT_MODEL=claude-3-opus
FALLBACK_MODEL=claude-3-sonnet

# Network Access (production)
MC_ALLOWED_HOSTS=localhost,127.0.0.1
MC_ALLOW_ANY_HOST=

# Data Retention (days)
MC_RETAIN_ACTIVITIES_DAYS=90
MC_RETAIN_AUDIT_DAYS=365
MC_RETAIN_TOKEN_USAGE_DAYS=90

# Server
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info
