# =====================================================
# Autonomous AI Startup - Environment Configuration
# =====================================================
# Copy this file to .env and configure for your environment:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED]
# All others have sensible defaults
# =====================================================

# ---- Core Settings ----
NODE_ENV=development                    # development | production
PORT=3000                               # Server port
LOG_LEVEL=info                          # debug | info | warn | error

# ---- Database ----
DATABASE_PATH=.data/startup.db          # SQLite database file path (relative to project root)

# ---- Authentication ----
AUTH_USER=admin                         # Dashboard admin username
AUTH_PASS=change-me-on-first-login      # [CHANGE THIS] Dashboard admin password
API_KEY=generate-a-random-api-key       # [CHANGE THIS] API key for programmatic access

# =====================================================
# OpenClaw Gateway Integration
# =====================================================
# Configure these to connect Mission Control to your
# OpenClaw instance for real-time agent communication.
#
# If you haven't installed OpenClaw yet:
#   npm install -g openclaw@latest
#   openclaw onboard --install-daemon
#   openclaw daemon start
# =====================================================

# Gateway Connection
OPENCLAW_GATEWAY_HOST=127.0.0.1         # OpenClaw Gateway hostname or IP
OPENCLAW_GATEWAY_PORT=18789             # OpenClaw Gateway port (default: 18789)
OPENCLAW_GATEWAY_TOKEN=                 # Gateway authentication token (if required)

# OpenClaw File Paths
OPENCLAW_CONFIG_PATH=                   # Path to openclaw.json (e.g., ~/.openclaw/openclaw.json)
OPENCLAW_STATE_DIR=                     # Path to .openclaw state directory (e.g., ~/.openclaw)
OPENCLAW_MEMORY_DIR=                    # Path to agent workspace (e.g., ~/clawd-agents)

# =====================================================
# AI Model Configuration
# =====================================================
DEFAULT_MODEL=claude-3-opus             # Primary AI model for agent operations
FALLBACK_MODEL=claude-3-sonnet          # Fallback model when primary is unavailable
OPENAI_API_KEY=                         # OpenAI API key (for knowledge embeddings, optional)

# =====================================================
# Network & Security (Production)
# =====================================================
MC_ALLOWED_HOSTS=localhost,127.0.0.1    # Comma-separated allowed hostnames
MC_ALLOW_ANY_HOST=                      # Set to "true" to allow any host (NOT recommended)

# =====================================================
# Data Retention (days)
# =====================================================
MC_RETAIN_ACTIVITIES_DAYS=90            # Activity log retention
MC_RETAIN_AUDIT_DAYS=365                # Audit log retention
MC_RETAIN_TOKEN_USAGE_DAYS=90           # Token usage data retention

# =====================================================
# Python Orchestration Layer (Optional)
# =====================================================
METRICS_PORT=9090                       # Metrics API port for Python orchestration
